{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "bash": "./core/scripts/retrospective-record.sh"
      },
      {
        "type": "command",
        "bash": "./core/scripts/generate-dashboard.sh",
        "comment": "Dashboard auto-update (async)"
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "./core/scripts/auto-commit.sh"
      }
    ]
  }
}
