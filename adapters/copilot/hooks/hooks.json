{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "bash": "./core/scripts/board-stamp.sh"
      },
      {
        "type": "command",
        "bash": "./core/scripts/retrospective-record.sh"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./core/scripts/auto-commit.sh"
      }
    ]
  }
}
