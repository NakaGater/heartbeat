{
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)"
    ],
    "allow": [
      "Bash(*)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.makeareadme.com)",
      "WebSearch",
      "mcp__playwright__*",
      "Write",
      "Edit"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./core/scripts/retrospective-record.sh"
          },
          {
            "type": "command",
            "command": "./core/scripts/generate-dashboard.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./core/scripts/auto-commit.sh"
          }
        ]
      }
    ]
  }
}
