{
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git rm *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)"
    ],
    "allow": [
      "Bash(*)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.makeareadme.com)",
      "WebSearch",
      "mcp__plugin_heartbeat_playwright__*",
      "Write",
      "Edit"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ]
}
