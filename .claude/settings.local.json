{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(shellspec *)",
      "Bash(make *)",
      "Bash(chmod +x *)",
      "Bash(command *)",
      "Bash(jq *)",
      "Bash(/opt/homebrew/bin/jq *)",
      "Bash(grep *)",
      "Bash(md5)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(sed *)",
      "Bash(date *)",
      "Bash(sort *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(npx *)",
      "Bash(bash *)",
      "Bash(while *)",
      "Bash(for *)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.makeareadme.com)",
      "WebSearch",
      "mcp__playwright__*"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./core/scripts/retrospective-record.sh"
          },
          {
            "type": "command",
            "command": "./core/scripts/generate-dashboard.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./core/scripts/auto-commit.sh"
          }
        ]
      }
    ]
  }
}
